{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "sourceMap": true,
      "strict": true,
      "moduleResolution": "NodeNext",
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "composite": true,
      "declaration": true,
      "declarationMap": true,
      "incremental": true,
      "skipLibCheck": true,
      "noEmitOnError": true
    }
  }